# Which LLM provider drives the agent's decisions: "anthropic" or "openai"
LLM_PROVIDER=anthropic

# Only the key matching LLM_PROVIDER is required at runtime
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Model name is optional; each provider adapter has a sane default if unset
ANTHROPIC_MODEL=claude-sonnet-5
OPENAI_MODEL=gpt-4o

# Operational safety limits (Principle VII)
DAILY_RUN_LIMIT=20
MAX_STEPS_PER_RUN=15

# Port the web server listens on (PaaS platforms like Zeabur inject this)
PORT=8000
